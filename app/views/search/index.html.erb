<div class="page" data-controller="appointment-modal">
  <header class="topbar">
    <div class="topbar__inner">
      <div class="brand">
        <%= image_tag "nutrium-logo.png", class: "brand__logo", alt: "Nutrium logo" %>
        <span class="brand__name">nutrium</span>
      </div>

      <a class="topbar__link" href="#">
        Are you a nutrition professional? Get to know our software →
      </a>
    </div>

    <div class="searchstrip">
      <div class="searchstrip__inner">
        <%= form_with url: root_path, method: :get, local: true, class: "searchform" do %>
          <div class="searchform__field">
            <%= text_field_tag :search_term, @query, placeholder: "Name, service, online appointment...", class: "input" %>
          </div>

          <div class="searchform__field searchform__field--location">
            <%= text_field_tag :location, @location.presence || "Braga", placeholder: "Location", class: "input" %>
            <span class="loc-dot" aria-hidden="true"></span>
          </div>

          <%= submit_tag "Search", class: "btn btn--search" %>
        <% end %>
      </div>
    </div>
  </header>

  <main class="content">
    <div class="content__inner">

      <% if @services.empty? %>
        <div class="empty">
          <p>No results.</p>
        </div>
      <% else %>
        <div class="results">
          <% @services.each do |s| %>
            <article class="card">
              <div class="card__left">
                <div class="avatar" aria-hidden="true">                
                  <svg xmlns="http://www.w3.org/2000/svg" 
                        viewBox="0 0 24 24" 
                        fill="none" 
                        stroke="currentColor" 
                        stroke-width="2" 
                        stroke-linecap="round" 
                        stroke-linejoin="round" 
                        class="avatar__icon">
                    <circle cx="12" cy="8" r="5"/>
                    <path d="M20 21a8 8 0 0 0-16 0"/>
                  </svg>
                </div>
                <div class="info">
                  <div class="badge">
                    <svg xmlns="http://www.w3.org/2000/svg" 
                          viewBox="0 0 24 24" 
                          fill="none" 
                          stroke="currentColor" 
                          stroke-width="2" 
                          stroke-linecap="round" 
                          stroke-linejoin="round" 
                          class="badge__icon">
                          <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/>
                      </svg>
                    FOLLOW-UP
                  </div>

                  <h2 class="name"><%= s.nutritionist.name %></h2>
                  <div class="meta">Dietitian • <%= s.nutritionist.id %></div>

                  <div class="details">
                    <div class="detail">
                      <span class="detail__text"><%= s.name %></span>
                    </div>

                    <div class="detail">
                      <span class="detail__text"><%= s.location_name %></span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="card__mid">
                <div class="midrow">
                  <span class="midrow__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" 
                          fill="none"                     
                          viewBox="0 0 24 24" 
                          stroke-width="1.5" 
                          stroke="currentColor" 
                          class="icon">
                      <path stroke-linecap="round" 
                            stroke-linejoin="round" 
                            d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z" />
                    </svg>
                  </span>

                  <span class="midrow__label">First appointment</span>
                  <span class="midrow__caret">▾</span>
                </div>

                <div class="midrow midrow--price">
                  <span class="midrow__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" 
                          fill="none" 
                          viewBox="0 0 24 24" 
                          stroke-width="1.5" 
                          stroke="currentColor" 
                          class="icon">
                      <path stroke-linecap="round" 
                            stroke-linejoin="round" 
                            d="M14.25 7.756a4.5 4.5 0 1 0 0 8.488M7.5 10.5h5.25m-5.25 3h5.25M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                  </span>

                  <span class="midrow__value"><%= s.price %> <%= s.currency %></span>
                </div>
              </div>

              <div class="card__right">
                <button
                  class="btn btn--primary"
                  data-action="click->appointment-modal#open"
                  data-appointment-modal-service-id-value="<%= s.id %>"
                  data-appointment-modal-service-name-value="<%= s.name %>"
                  data-appointment-modal-nutritionist-name-value="<%= s.nutritionist.name %>"
                >
                  Schedule appointment
                </button>

                <a class="btn btn--ghost" href="#" aria-disabled="true">
                  Personal Page
                </a>
              </div>
            </article>
          <% end %>
        </div>

        <nav class="pagination" aria-label="Pagination">
          <a class="pagebtn" href="#" aria-label="Previous">‹</a>
          <a class="pagebtn is-active" href="#">1</a>
          <a class="pagebtn" href="#">2</a>
          <a class="pagebtn" href="#">3</a>
          <a class="pagebtn" href="#">4</a>
          <a class="pagebtn" href="#">5</a>
          <a class="pagebtn" href="#">6</a>
          <a class="pagebtn" href="#" aria-label="Next">›</a>
        </nav>
      <% end %>

    </div>
  </main>

  <div
    class="modal"    
    data-appointment-modal-target="backdrop"
    data-action="click->appointment-modal#backdropClose keydown@document->appointment-modal#onKeydown"
  >
    <div class="modal__panel" role="dialog" aria-modal="true">
      <h2 class="modal__title" data-appointment-modal-target="title">Schedule appointment</h2>

      <%= form_with url: appointment_requests_path,
              method: :post,
              local: true,
              class: "modal__form" do %>
        <%= hidden_field_tag "appointment_request[service_id]", "", data: { appointment_modal_target: "serviceId" } %>

        <label class="field">
          <span class="field__label"> Name </span>
          <%= text_field_tag "appointment_request[guest_name]", nil, required: true, class: "input", placeholder: "Introduce your name..." %>
        </label>

        <label class="field">
          <span class="field__label">Email</span>
          <%= email_field_tag "appointment_request[guest_email]", nil, required: true, class: "input", placeholder: "Introduce your email..."  %>
        </label>

        <div class="grid2">
          <label class="field">
            <span class="field__label">Date</span>
            <%= date_field_tag "appointment_request[date]", nil, required: true, min: Date.current, class: "input" %>
          </label>

          <label class="field">
            <span class="field__label">Time</span>
            <%= time_field_tag "appointment_request[time]", nil, required: true, class: "input" %>
          </label>
        </div>

        <div class="modal__actions">
          <%= submit_tag "Submit request", class: "btn btn--primary" %>
          <button type="button" class="btn btn--danger" data-action="click->appointment-modal#close">
            Cancel
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>